<?xml version="1.0" encoding="utf-8"?>
<!-- Calendar Widget — 4×2 — Shows today's delivery status -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_cal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header: title + date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="YesBill Calendar"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_cal_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#AA818CF8"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:background="#33FFFFFF" />

    <!-- Body: stats on left, service list on right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left: delivered count -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/widget_cal_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="–"
                    android:textColor="#FF6366F1"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_cal_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:text="/–"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="delivered today"
                android:textColor="#80FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Right: up to 4 service rows -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Service row 1 -->
            <LinearLayout
                android:id="@+id/widget_cal_s1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/widget_cal_s1_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_cal_s1_dot"
                    android:layout_width="14dp"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Service row 2 -->
            <LinearLayout
                android:id="@+id/widget_cal_s2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/widget_cal_s2_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_cal_s2_dot"
                    android:layout_width="14dp"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Service row 3 -->
            <LinearLayout
                android:id="@+id/widget_cal_s3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/widget_cal_s3_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_cal_s3_dot"
                    android:layout_width="14dp"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Service row 4 -->
            <LinearLayout
                android:id="@+id/widget_cal_s4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_cal_s4_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_cal_s4_dot"
                    android:layout_width="14dp"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
